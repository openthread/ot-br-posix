#!/bin/bash
# Unified path configuration for traefik enrollment service
# Can be sourced by bash scripts and parsed by Python
#
# DESIGN PRINCIPLE: Separate directories from filenames for flexibility
# - Directory variables: Context-dependent (absolute for system, relative for scripts/tests)
# - Filename variables: Just the filename, combined with directory at runtime
#
# USAGE IN BASH:
#   SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
#   source "${SCRIPT_DIR}/paths.env"
#   # For system scripts (CWD=/var/lib/traefik): CERTS_DIR=./certs
#   # For test scripts: CERTS_DIR=./test-certs
#   # Then: IDEVID_PATH="${CERTS_DIR}/${IDEVID_CHAIN}"
#
# USAGE IN PYTHON:
#   from config import CONFIG
#   idevid_path = os.path.join(CONFIG['certs_dir'], CONFIG['idevid_chain'])
#
# IMPORTANT: This file uses KEY=VALUE format without spaces around =
# to ensure compatibility with both bash sourcing and Python parsing

# Traefik binary
TRAEFIK_BIN=/opt/traefik/traefik

# Base directories (absolute paths for system context)
TRAEFIK_DATA_DIR=/var/lib/traefik

# Working directories (relative paths, can be overridden)
CERTS_DIR=certs
AUTH_DIR=auth

# Configuration files
STATIC_CONFIG_FILE=traefik.yml
DYNAMIC_CONFIG_FILE=dynamic.yml
# Basic Auth database (combine with AUTH_DIR)
HTPASSWD_FILE=htpasswd

# Certificate files (combine with CERTS_DIR)
CA_BUNDLE=ca-bundle.pem
CLIENT_CERTS_SUBDIR=clients
IDEVID_CHAIN=idevid-chain.pem
IDEVID_KEY=idevid-key.pem
LDEVID_CHAIN=ldevid-chain.pem
LDEVID_KEY=ldevid-key.pem
ACTIVE_CHAIN=active-chain.pem
ACTIVE_KEY=active-key.pem
ROOT_CA_CERT=root-ca-cert.pem
ROOT_CA_KEY=root-ca-key.pem
ISSUING_CA_CERT=issuing-ca-cert.pem
ISSUING_CA_KEY=issuing-ca-key.pem
# Client authorization database (combine with CERTS_DIR / CLIENT_CERTS_SUBDIR)
CLIENT_AUTHZ=client-authz.json

# Authentication files (just filenames, combine with AUTH_DIR)
TOKEN_SECRET_FILE=token_secret
TOKENS_DB_FILE=tokens.db
