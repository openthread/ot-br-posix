if test "$1" -eq 256 ; then
  e=$((128 + $2))
else
  e="$1"
fi

echo "otbr-agent exited with code ${1} (by signal ${2})."

# IPv6 ingress filter teardown is no longer required here: when otbr-agent is
# built with OTBR_NFTABLES=ON (the default), the FirewallManager owns the
# `inet otbr` table lifecycle. Stale state from a previous run is cleared by
# the next FirewallManager::Init() (DelTable is idempotent). For OTBR_NFTABLES
# =OFF builds, restore the legacy ipset/ip6tables teardown that previously
# lived here.

if test "$e" -ne 0; then
    echo "$e" > /run/s6-linux-init-container-results/exitcode
    /run/s6/basedir/bin/halt
    exit 125
fi
