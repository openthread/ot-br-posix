meta {
  name: PUT /.well-known/thread/ldevid (409 if device-generated cert active)
  type: http
  seq: 1005
  tags: secure-enrollment-server
}

put {
  url: {{protocol}}://{{host}}:{{port}}/.well-known/thread/ldevid
  body: text
  auth: none
}

script:pre-request {
  const authMode = bru.getEnvVar("auth_mode");

  if (authMode === "basic") {
    const username = bru.getEnvVar("admin_user");
    const password = bru.getEnvVar("admin_pass");
    const credentials = Buffer.from(`${username}:${password}`).toString('base64');
    req.setHeader("Authorization", `Basic ${credentials}`);
  }
}

headers {
  Content-Type: application/x-pem-file
}

body:text {
  {{client_cert_pem}}
}

assert {
  res.status: eq 409
}

tests {
  test("PUT /ldevid returns 409 when device-generated (self-signed) LDevID is active", function() {
    expect(res.status).to.equal(409);
    const body = res.getBody();
    expect(body).to.have.property('title');
  });
}

docs {
  Test PUT /.well-known/thread/ldevid when the active LDevID certificate was
  generated by the device via generateLDevIdTask (self-signed cert).

  Per the OpenAPI specification (PUT /.well-known/thread/ldevid):
    "Requires ex-factory state or previous enrollment using the same method
     (no use of generateLDevIdTask); otherwise returns 409 Conflict."

  Precondition: Device must have an active self-signed LDevID
  (i.e., generateLDevIdTask completed and POST /api/auth/enroll was called).

  In this state the device holds the private key and PUT is blocked to
  preserve key custody — the client must use POST /api/auth/enroll (EST pull)
  to renew the certificate without transferring key custody.

  See: docs/specs/openapi.yaml PUT /.well-known/thread/ldevid 409 response
}
