meta {
  name: GET .well-known/thread/csr
  type: http
  seq: 1005
  tags: secure-enrollment-server
}

get {
  url: {{protocol}}://{{host}}:{{port}}/.well-known/thread/csr
  body: none
  auth: basic
}

auth:basic {
  username: {{admin_user}}
  password: {{admin_pass}}
}

headers {
  Accept: application/pkcs10
}

assert {
  res.status: eq 200
  res.headers.content-type: contains pkcs10
}

tests {
  test("CSR retrieved successfully", function() {
    expect(res.status).to.equal(200);
    expect(res.getHeader('content-type')).to.contain('pkcs10');
  });
}

docs {
  Test 5.1: Generate CSR
  
  Retrieves a Certificate Signing Request (CSR) in PKCS#10 format
  for CA-signed LDevID enrollment.
  
  The CSR includes:
  - Public key generated by TBR
  - Subject with TBR hostname  
  - SAN matching TBR hostname
}
