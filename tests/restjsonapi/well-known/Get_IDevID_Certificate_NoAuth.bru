meta {
  name: GET IDevID Certificate
  type: http
  seq: 1001
  tags: secure-enrollment-server
}

get {
  url: {{protocol}}://{{host}}:{{port}}/.well-known/thread/idevid
  body: none
  auth: none
}

headers {
  Accept: application/pkcs7-mime
}

assert {
  res.status: eq 200
  res.headers['content-type']: contains pkcs7-mime
}

tests {
  test("IDevID certificate retrieved in PKCS#7 format", function() {
    expect(res.status).to.equal(200);
    expect(res.headers['content-type']).to.contain('pkcs7-mime');
    // Response body will be binary PKCS#7 DER format
  });
}

docs {
  Test 1.2: Get IDevID certificate (ex-factory)
  
  Retrieves the factory-assigned IDevID certificate in PKCS#7 format.
  This is the manufacturer device certificate following IEEE 802.1AR.
}
