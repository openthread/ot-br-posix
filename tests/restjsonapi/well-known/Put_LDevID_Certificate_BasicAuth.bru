meta {
  name: PUT .well-known/thread/ldevid (CA-signed)
  type: http
  seq: 1004
  tags: secure-enrollment-server
}

put {
  url: {{protocol}}://{{host}}:{{port}}/.well-known/thread/ldevid
  body: text
  auth: basic
}

auth:basic {
  username: {{admin_user}}
  password: {{admin_pass}}
}

headers {
  Content-Type: application/x-pem-file
}

body:text {
  {{ldevid_cert_pem}}
}

assert {
  res.status: eq 204
}

tests {
  test("CA-signed LDevID uploaded successfully", function() {
    expect(res.status).to.equal(204);
  });
}

docs {
  Test 4.1/5.2: Upload CA-signed LDevID certificate
  
  Uploads a CA-signed LDevID certificate and private key.
  The certificate must be in PEM format and include the full chain.
  
  Note: Use environment variable containing
  the certificate and key in PEM format.
}
