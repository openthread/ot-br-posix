meta {
  name: GET Node with New Password
  type: http
  seq: 5
}

get {
  url: {{protocol}}://{{host}}:{{port}}{{base_path}}/node
  body: none
  auth: basic
}

auth:basic {
  username: {{admin_user}}
  password: {{new_admin_pass}}
}

headers {
  Accept: application/vnd.api+json
}

assert {
  res.status: eq {{node_get_expected_status}}
}

tests {
  test("New password authentication works", function() {
    const expectedStatus = Number(bru.getEnvVar("node_get_expected_status"));
    expect(res.status).to.equal(expectedStatus);
    
    if (res.status === 200) {
      const authMode = bru.getEnvVar("auth_mode");
      console.log(`Access allowed (${authMode} mode)`);

      const data = res.getBody();
      expect(data).to.have.property('data');
      expect(data.data).to.have.property('type');
      expect(data.data.type).to.equal('threadBorderRouter');
      console.log("✓ New password authentication successful");
    } else if (res.status === 401 || res.status === 403) {
      console.log("Access denied (requires auth)");
    } else {
      console.log(`Access failed`);
    }
  });
}

docs {
  Verifies new password works for authentication.
}
