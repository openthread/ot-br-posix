meta {
  name: PUT Change Password
  type: http
  seq: 4
}

put {
  url: {{protocol}}://{{host}}:{{port}}{{base_path}}/auth/password
  body: text
  auth: none
}

script:pre-request {
  const authMode = bru.getEnvVar("auth_mode");
  
  if (authMode === "basic") {
    const username = bru.getEnvVar("admin_user");
    const password = bru.getEnvVar("admin_pass");
    const credentials = Buffer.from(`${username}:${password}`).toString('base64');
    req.setHeader("Authorization", `Basic ${credentials}`);
  }
}

headers {
  Content-Type: text/plain; charset=UTF-8
}

body:text {
  {{new_admin_pass}}
}

assert {
  res.status: eq {{password_put_expected_status}}
}

tests {
  test("Password change completed", function() {
    const expectedStatus = Number(bru.getEnvVar("password_put_expected_status"));
    expect(res.status).to.equal(expectedStatus);
    
    if (res.status === 204) {
      const authMode = bru.getEnvVar("auth_mode");
      console.log(`Access allowed (${authMode} mode)`);
    } else if (res.status === 401 || res.status === 403) {
      console.log("Access denied (requires auth)");
    } else {
      console.log(`Access failed`);
    }
  });
}

script:post-response {
  // Wait 5 seconds for password change to propagate through the system
  const sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));
  await sleep(5000);
  console.log("⏱ Waited 5 seconds for password change to propagate");
}

docs {
  Changes admin password from default to secure password.
}
