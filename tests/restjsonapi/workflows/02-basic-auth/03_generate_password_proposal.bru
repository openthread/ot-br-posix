meta {
  name: POST Generate Password Proposal
  type: http
  seq: 3
}

post {
  url: {{protocol}}://{{host}}:{{port}}{{base_path}}/auth/password
  body: none
  auth: none
}

script:pre-request {
  const authMode = bru.getEnvVar("auth_mode");
  
  if (authMode === "basic") {
    const username = bru.getEnvVar("admin_user");
    const password = bru.getEnvVar("admin_pass");
    const credentials = Buffer.from(`${username}:${password}`).toString('base64');
    req.setHeader("Authorization", `Basic ${credentials}`);
  }
}

headers {
  Accept: text/plain
}

assert {
  res.status: eq {{password_post_expected_status}}
}

tests {
  test("Password proposal generated", function() {
    const expectedStatus = Number(bru.getEnvVar("password_post_expected_status"));
    expect(res.status).to.equal(expectedStatus);
    
    if (res.status === 200) {
      const authMode = bru.getEnvVar("auth_mode");
      console.log(`Access allowed (${authMode} mode)`);
    } else if (res.status === 401 || res.status === 403) {
      console.log("Access denied (requires auth)");
    } else {
      console.log(`Access failed`);
    }
  });
  
  test("Password policy check", function() {
    if (res.status === 200) {
      const password = res.getBody();
      // Password policy: 16-24 bytes, no control characters
      expect(password.length).to.be.at.least(16);
      expect(password.length).to.be.at.most(24);
      expect(password).to.not.match(/[\x00-\x1F\x7F]/);
    }
  });
}

docs {
  Generates password proposal meeting policy requirements (16-24 bytes).
}
