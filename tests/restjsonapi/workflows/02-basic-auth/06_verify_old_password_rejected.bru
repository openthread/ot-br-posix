meta {
  name: GET Node with Old Password (Should Fail)
  type: http
  seq: 6
}

get {
  url: {{protocol}}://{{host}}:{{port}}{{base_path}}/node
  body: none
  auth: basic
}

auth:basic {
  username: {{admin_user}}
  password: thread
}

headers {
  Accept: application/vnd.api+json
}

assert {
  res.status: eq {{wrong_password_expected_status}}
}

tests {
  test("Old password is rejected after change", function() {   
    const expectedStatus = parseInt(bru.getEnvVar('wrong_password_expected_status'));
    expect(res.status).to.equal(expectedStatus);
    
    if (res.status === 200) {
      const authMode = bru.getEnvVar("auth_mode");
      console.log(`Access allowed (${authMode} mode)`);
    } else if (res.status === 401 || res.status === 403) {
      console.log("Access denied (requires auth)");
    } else {
      console.log(`Access failed`);
    }

  });
}

docs {
  Verifies old password is rejected after change.
}
