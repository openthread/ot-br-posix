meta {
  name: GET LDevID - Verify Active
  type: http
  seq: 1
}

get {
  url: {{protocol}}://{{host}}:{{port}}/.well-known/thread/ldevid
  body: none
  auth: none
}

script:pre-request {
  const authMode = bru.getEnvVar("auth_mode");
  
  if (authMode === "basic") {
    const username = bru.getEnvVar("admin_user");
    const password = bru.getEnvVar("admin_pass");
    const credentials = Buffer.from(`${username}:${password}`).toString('base64');
    req.setHeader("Authorization", `Basic ${credentials}`);
  }
}

headers {
  Accept: application/pkcs7-mime
}

assert {
  res.status: eq {{ldevid_get_expected_status}}
}

tests {
  test("LDevID certificate is available and active", function() {
    const expectedStatus = Number(bru.getEnvVar("ldevid_get_expected_status"));
    
    expect(res.status).to.equal(expectedStatus);
    
    if (res.status === 200) {
      expect(res.getHeader('content-type')).to.contain('pkcs7-mime');
      const bodyLength = res.getBody().length;
      expect(bodyLength).to.be.greaterThan(0);
      console.log(`✓ LDevID certificate verified (${bodyLength} bytes)`);
      console.log("  Certificate is now active and serving HTTPS traffic");
    }
  });
  
  test("Server is using the new certificate", function() {
    if (res.status === 200) {
      // If we can connect and retrieve the cert, server successfully reloaded
      console.log("✓ Server successfully reloaded with new LDevID certificate");
      console.log("  Note: This is the self-signed certificate from Phase 3.1");
    }
  });
}

docs {
  Verifies self-signed LDevID certificate is active.
}
