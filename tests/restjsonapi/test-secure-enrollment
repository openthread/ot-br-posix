##############################################################
## Test Summary
##############################################################
echo -e "\n${BLUE}=== Test Summary ===${NC}"

# Count individual test results from all result files
TOTAL_ASSERTIONS=0
PASSED_ASSERTIONS=0
FAILED_ASSERTIONS=0
TLS_ERRORS=0
RESULT_FILE_COUNT=$(ls results-sec-enroll*.json 2>/dev/null | wc -l)

if [ "$RESULT_FILE_COUNT" -gt 0 ]; then
    # Parse each result file and count individual assertions
    for result_file in results-sec-enroll*.json; do
        if [ -f "$result_file" ]; then
            # Count assertions in this file (Bruno format: array of collections, each with results array)
            # Each result has assertionResults array
            FILE_TOTAL=$(jq '[.[].results[].assertionResults[] // []] | length' "$result_file" 2>/dev/null || echo "0")
            FILE_PASSED=$(jq '[.[].results[].assertionResults[] | select(.status == "pass")] | length' "$result_file" 2>/dev/null || echo "0")
            FILE_FAILED=$(jq '[.[].results[].assertionResults[] | select(.status == "fail")] | length' "$result_file" 2>/dev/null || echo "0")

            # Count TLS/network errors (status: "error" with no assertionResults)
            FILE_TLS_ERRORS=$(jq '[.[].results[] | select(.status == "error")] | length' "$result_file" 2>/dev/null || echo "0")

            TOTAL_ASSERTIONS=$((TOTAL_ASSERTIONS + FILE_TOTAL))
            PASSED_ASSERTIONS=$((PASSED_ASSERTIONS + FILE_PASSED))
            FAILED_ASSERTIONS=$((FAILED_ASSERTIONS + FILE_FAILED))
            TLS_ERRORS=$((TLS_ERRORS + FILE_TLS_ERRORS))
        fi
    done

    echo -e "${GREEN}Test Results from $RESULT_FILE_COUNT result file(s):${NC}"
    echo "  Assertions:"
    echo "    - Total: $TOTAL_ASSERTIONS"
    echo "    - Passed: $PASSED_ASSERTIONS"
    echo "    - Failed: $FAILED_ASSERTIONS"

    if [ "$TLS_ERRORS" -gt 0 ]; then
        echo -e "  ${RED}TLS/Network Errors: $TLS_ERRORS${NC}"
        echo "    (Tests that failed to connect - likely certificate validation issues)"
    fi

    if [ "$FAILED_ASSERTIONS" -gt 0 ]; then
        echo ""
        echo -e "${RED}Failed Assertions:${NC}"
        for result_file in results-sec-enroll*.json; do
            if [ -f "$result_file" ]; then
                # Extract failed assertions with test name and error
                jq -r '.[].results[] | select(.assertionResults[] | select(.status == "fail")) | "  - \(.test.filename): \(.assertionResults[] | select(.status == "fail") | .error)"' "$result_file" 2>/dev/null
            fi
        done
    fi

    if [ "$TLS_ERRORS" -gt 0 ]; then
        echo ""
        echo -e "${RED}TLS/Network Errors (sample):${NC}"
        # Show first 5 unique error messages
        for result_file in results-sec-enroll*.json; do
            if [ -f "$result_file" ]; then
                jq -r '.[].results[] | select(.status == "error") | "  - \(.test.filename): \(.error)"' "$result_file" 2>/dev/null
            fi
        done | sort -u | head -5
    fi

    echo ""
    echo "  - Result files: results-sec-enroll*.json"
else
    echo -e "${YELLOW}No test results found${NC}"
fi

echo ""
echo -e "${BLUE}Test suite completed.${NC}"
echo ""

# Cleanup EST server if running
if [ -n "${EST_SERVER_PID:-}" ] && kill -0 $EST_SERVER_PID 2>/dev/null; then
    echo "Stopping EST server (PID: $EST_SERVER_PID)..."
    kill $EST_SERVER_PID 2>/dev/null || true
    wait $EST_SERVER_PID 2>/dev/null || true
fi

# Cleanup temporary EST server directory
if [ -n "${EST_DIR:-}" ] && [ -d "$EST_DIR" ]; then
    rm -rf "$EST_DIR"
fi
