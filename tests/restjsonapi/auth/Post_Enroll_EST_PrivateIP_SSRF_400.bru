meta {
  name: POST /api/auth/enroll (EST Pull, private IP blocked by SSRF guard)
  type: http
  seq: 1004
  tags: secure-enrollment-server
}

post {
  url: {{protocol}}://{{host}}:{{port}}{{base_path}}/auth/enroll
  body: json
  auth: none
}

script:pre-request {
  const authMode = bru.getEnvVar("auth_mode");

  if (authMode === "basic") {
    const username = bru.getEnvVar("admin_user");
    const password = bru.getEnvVar("admin_pass");
    const credentials = Buffer.from(`${username}:${password}`).toString('base64');
    req.setHeader("Authorization", `Basic ${credentials}`);
  }
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "est_server": "https://127.0.0.1:9999"
  }
}

assert {
  res.status: eq 400
}

tests {
  test("EST pull with loopback address is rejected as SSRF risk", function() {
    expect(res.status).to.equal(400);
    const body = res.getBody();
    expect(body).to.have.property('title');
  });
}

docs {
  Test POST /api/auth/enroll with est_server pointing to loopback address.

  When tls_verify is true (the default when omitted from the request body),
  the SSRF guard MUST reject requests to loopback (127.x), RFC1918 private
  (10.x, 172.16-31.x, 192.168.x), and link-local (169.254.x) addresses with
  400 Bad Request.

  This protects against Server-Side Request Forgery attacks where a management
  client could be tricked into probing internal infrastructure.

  See: OWASP SSRF (CWE-918)
  Companion test: Post_Enroll_EST_Pull_TLSVerifyFalse_PrivateIP.bru
  (with tls_verify=false, the operator explicitly bypasses the SSRF guard)
}
