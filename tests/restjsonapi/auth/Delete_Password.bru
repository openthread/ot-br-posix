meta {
  name: DELETE /api/auth/password
  type: http
  seq: 1011
  tags: client-basic-auth
}

delete {
  url: {{protocol}}://{{host}}:{{port}}{{base_path}}/auth/password
  body: none
  auth: none
}

script:pre-request {
  const authMode = bru.getEnvVar("auth_mode");

  if (authMode === "basic") {
    const username = bru.getEnvVar("admin_user");
    const password = bru.getEnvVar("admin_pass");
    const credentials = Buffer.from(`${username}:${password}`).toString('base64');
    req.setHeader("Authorization", `Basic ${credentials}`);
  }
  // mtls: client certificate provided via --client-cert-config (no Authorization header needed)
  // noAuth: no credentials sent
}

assert {
  res.status: eq {{delete_password_expected_status}}
}

tests {
  test("DELETE password", function() {
    const expectedStatus = parseInt(bru.getEnvVar("delete_password_expected_status"));
    expect(res.status).to.equal(expectedStatus);

    if (res.status === 204) {
      const authMode = bru.getEnvVar("auth_mode");
      console.log(`Password deleted successfully (${authMode} mode) - mTLS is now the sole authentication method`);
    } else if (res.status === 409) {
      console.log("Password deletion rejected - no admin client certificate enrolled (correct)");
    } else if (res.status === 401) {
      console.log("Access denied - authentication required (correct)");
    } else if (res.status === 403) {
      console.log("Access denied - insufficient permissions (correct)");
    } else {
      const errorMessage = res.body?.error || res.body?.message || "Unknown error";
      console.log(`Unexpected: ${errorMessage}`);
    }
  });
}

docs {
  Test: DELETE /api/auth/password

  Removes the admin password, disabling Basic Authentication.
  Requires at least one admin client certificate to be enrolled; otherwise returns 409 Conflict.

  Expected status per environment:
  - baseline:       401  (no authentication configured)
  - initial-state:  409  (no client certificates enrolled)
  - enrolled:       409  (no client certificates enrolled yet)
  - mtls-mode:      204  (admin client cert enrolled, mTLS active — safe to delete password)
  - mtls-mode-403:  403  (unauthorized client certificate)
}
