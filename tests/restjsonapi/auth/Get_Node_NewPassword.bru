meta {
  name: GET Node with New Password
  type: http
  seq: 1011
  tags: client-basic-auth
}

get {
  url: {{protocol}}://{{host}}:{{port}}{{base_path}}/node
  body: none
  auth: basic
}

auth:basic {
  username: {{admin_user}}
  password: {{new_admin_pass}}
}

headers {
  Accept: application/vnd.api+json
}

assert {
  res.status: eq 200
  res.headers['content-type']: eq application/vnd.api+json
  res.body: isJson
  res.body.data.type: eq "threadBorderRouter"
}

tests {
  test("New password accepted", function() {
    expect(res.status).to.equal(200);
  });
}

docs {
  Test 2.6: Verify new password is accepted
  
  Verifies that the newly changed password works for authentication.
  Uses the new_admin_pass variable from the environment.
}
