meta {
  name: POST Generate Password Proposal
  type: http
  seq: 1001
  tags: client-basic-auth
}

post {
  url: {{protocol}}://{{host}}:{{port}}{{base_path}}/auth/password
  body: none
  auth: basic
}

auth:basic {
  username: {{admin_user}}
  password: {{admin_pass}}
}

headers {
  Accept: text/plain
}

assert {
  res.status: eq 200
  res.headers['content-type']: contains text/plain
}

tests {
  test("Password proposal generated", function() {
    const password = res.getBody();
    expect(res.status).to.equal(200);
    expect(password).to.be.a('string');
    expect(password.length).to.be.at.least(16);
    expect(password.length).to.be.at.most(24);
    console.log("Generated password proposal:", password);
  });
}

docs {
  Test 2.4: POST /api/auth/password (generate password proposal)
  
  Generates a password proposal that meets password policy requirements:
  - 16 to 24 bytes in length (UTF-8)
  - No UTF-8 control characters
}
