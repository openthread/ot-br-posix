meta {
  name: PUT Change Password
  type: http
  seq: 1002
  tags: client-basic-auth
}

put {
  url: {{protocol}}://{{host}}:{{port}}{{base_path}}/auth/password
  body: text
  auth: basic
}

auth:basic {
  username: {{admin_user}}
  password: {{admin_pass}}
}

headers {
  Content-Type: text/plain; charset=UTF-8
}

body:text {
  NewSecurePassword123!
}

assert {
  res.status: eq 204
}

tests {
  test("Password changed successfully", function() {
    expect(res.status).to.equal(204);
  });
}

docs {
  Test 2.5: Change default password
  
  Changes the password for the admin user.
  Password must meet requirements:
  - minimum 12 characters
  - maximum 255 bytes
  - no control characters
  - three out of four: uppercase, lowercase, digit, non-alphanumeric
}
