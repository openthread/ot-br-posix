meta {
  name: GET /api/node with old password (401)
  type: http
  seq: 1003
  tags: client-basic-auth
}

get {
  url: {{protocol}}://{{host}}:{{port}}{{base_path}}/node
  body: none
  auth: basic
}

auth:basic {
  username: {{admin_user}}
  password: {{admin_pass}}
}

headers {
  Accept: application/vnd.api+json
}

assert {
  res.status: eq 401
}

tests {
  test("Old password is rejected after change", function() {
    expect(res.status).to.equal(401);
  });
}

docs {
  Test 2.7: Verify old password is rejected
  
  After changing the password, the old password should no longer work.
  This test uses the default password "thread" which should be rejected
  if the password was changed.
}
