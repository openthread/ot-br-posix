meta {
  name: PUT /api/auth/password (No Auth - 401)
  type: http
  seq: 1000
  tags: client-basic-auth
}

put {
  url: {{protocol}}://{{host}}:{{port}}{{base_path}}/auth/password
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "password": "testpass123"
  }
}

assert {
  res.status: eq 401
}

tests {
  test("PUT password requires authentication", function() {
    expect(res.status).to.equal(401);
  });
}

docs {
  Test 2.3: Verify PUT /api/auth/password requires authentication
  
  Attempting to change the password without authentication
  should be rejected with HTTP 401.
}
