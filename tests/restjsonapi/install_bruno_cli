# Install Bruno CLI
#

set -euxo pipefail

# Check if npm is already available
if command -v npm &>/dev/null; then
    echo "npm is already available, skipping fnm installation"
    node -v
    npm -v
else
    echo "npm not found, installing via fnm"
    # installs fnm (Fast Node Manager)
    if ! command -v fnm &>/dev/null; then
        curl -fsSL https://fnm.vercel.app/install | bash
    fi
    # Always ensure fnm environment is set up in current shell
    export PATH="$HOME/.local/share/fnm:$PATH"
    eval "$(fnm env --use-on-cd)"
    # download and install Node.js
    fnm use --install-if-missing 24 || true # continue if already installed
    # verifies the right Node.js version is in the environment
    node -v # should print `v24.x.x`
    # verifies the right npm version is in the environment
    npm -v # should print `11.x.x`
fi

# install Bruno CLI
npm install -g @usebruno/cli
bru --version
